# ─── Telegram Alerts ──────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your chat ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── PostgreSQL / TimescaleDB (Docker Compose) ─────────────────
# Relational metadata (assets, corporate actions, MSI/Cogencis metadata, etc.)
# PG_RELATIONAL_DSN=host=localhost port=5432 dbname=artha_relational user=artha password=artha_dev_password

# Time-series data (daily_prices, fundamentals, FF factors, etc.)
# PG_TIMESERIES_DSN=host=localhost port=5433 dbname=artha_timeseries user=artha password=artha_dev_password

# MSI Auth Token (MarketSmith India)
# MSI_AUTH_TOKEN=Bearer eyJ...

# ─── Cogencis (iinvest.cogencis.com) ──────────────────────────
# Get from browser DevTools while logged into iinvest.cogencis.com:
#   Network tab → any data.cogencis.com request → Request Headers
#   Copy the "Authorization: Bearer <token>" value
# COGENCIS_BEARER_TOKEN=eyJ...
#
# Alternatively, paste the full Cookie: header string
# COGENCIS_COOKIE=next-auth.token=eyJ...; next-auth.session-token=...
#
# Optional: override the Referer header
# COGENCIS_REFERER=https://iinvest.cogencis.com/
