0:{"buildId":"PKL10v0f3kEgSwbXWeYxN","rsc":["$","$1","c",{"children":[null,[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is Mutual Fund Tax Harvesting?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Tax Harvesting is the strategy of selling equity mutual funds up to ₹1.25 Lakhs in Long-Term Capital Gains (LTCG) every financial year to pay zero tax, and immediately reinvesting the money to reset your purchase price (NAV).\"}},{\"@type\":\"Question\",\"name\":\"How much tax can I save with Tax Harvesting?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Since LTCG up to ₹1.25 Lakhs is exempt from tax, and the tax rate above that is 12.5%, you can effectively save up to ₹15,625 (12.5% of 1.25 Lakhs) in taxes every single financial year by utilizing this strategy.\"}}]}"}}],["$","$L2",null,{"parallelRouterKey":"children","template":["$","$L3",null,{}]}]]]}],"loading":null,"isPartial":false}
